{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and global health statistics",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Routine": {
      "title": "Routine",
      "description": "A health task or habit tracked by the user",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["physical", "mental", "nutrition", "habit"] },
        "frequency": { "type": "string", "enum": ["daily", "weekly"] },
        "completed": { "type": "boolean" },
        "streak": { "type": "integer" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "userId"]
    },
    "Progress": {
      "title": "Progress",
      "description": "Daily completion rate statistics",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "completionRate": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["date", "completionRate", "userId"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message between user and health buddy",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "timestamp": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["role", "content", "timestamp", "userId"]
    },
    "Goal": {
      "title": "Goal",
      "description": "User specific health goals",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["weight", "water", "sleep", "steps"] },
        "target": { "type": "number" },
        "current": { "type": "number" },
        "unit": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["type", "target", "userId"]
    },
    "HealthInsight": {
      "title": "HealthInsight",
      "description": "AI-generated health assessment",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "timestamp": { "type": "number" },
        "category": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["content", "timestamp", "userId"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Detailed user health metrics",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "age": { "type": "number" },
        "weight": { "type": "number" },
        "height": { "type": "number" },
        "gender": { "type": "string" },
        "activityLevel": { "type": "string" },
        "dailyCalorieTarget": { "type": "number" },
        "onboarded": { "type": "boolean" }
      },
      "required": ["name", "onboarded"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/users/{userId}/profile/data": {
      "schema": "UserProfile",
      "description": "Historical health metrics and preferences"
    },
    "/users/{userId}/routines/{routineId}": {
      "schema": "Routine",
      "description": "User's individual health routines"
    },
    "/users/{userId}/progress/{dateId}": {
      "schema": "Progress",
      "description": "Daily progress tracking records"
    },
    "/users/{userId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat history for the user"
    },
    "/users/{userId}/goals/{goalId}": {
      "schema": "Goal",
      "description": "User goals"
    },
    "/users/{userId}/insights/{insightId}": {
      "schema": "HealthInsight",
      "description": "Weekly/Daily AI insights"
    }
  }
}
