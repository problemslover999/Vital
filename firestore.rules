rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.keys().size() >= 2 &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 128;
    }

    function isValidRoutine(data) {
      return data.keys().hasAll(['title', 'category', 'userId']) &&
             data.title is string && data.title.size() <= 100 &&
             data.category in ['physical', 'mental', 'nutrition', 'habit'] &&
             data.userId == request.auth.uid &&
             (!('streak' in data) || data.streak is int) &&
             (!('completed' in data) || data.completed is bool);
    }

    function isValidProgress(data) {
      return data.keys().hasAll(['date', 'completionRate', 'userId']) &&
             data.date is string && data.date.size() <= 20 &&
             data.completionRate is number &&
             data.userId == request.auth.uid;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['role', 'content', 'timestamp', 'userId']) &&
             data.role in ['user', 'model'] &&
             data.content is string && data.content.size() <= 5000 &&
             data.timestamp is number &&
             data.userId == request.auth.uid;
    }

    function isValidGoal(data) {
      return data.keys().hasAll(['type', 'target', 'userId']) &&
             data.type in ['weight', 'water', 'sleep', 'steps'] &&
             data.target is number &&
             data.userId == request.auth.uid;
    }

    function isValidInsight(data) {
      return data.keys().hasAll(['content', 'timestamp', 'userId']) &&
             data.content is string && data.content.size() <= 10000 &&
             data.timestamp is number &&
             data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastActive', 'email']);
      
      match /routines/{routineId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(routineId);
        allow create: if isOwner(userId) && isValidId(routineId) && isValidRoutine(incoming());
        allow update: if isOwner(userId) && isValidId(routineId) && isValidRoutine(incoming()) &&
                        incoming().userId == existing().userId;
        allow delete: if isOwner(userId) && isValidId(routineId);
      }

      match /progress/{dateId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(dateId);
        allow create: if isOwner(userId) && isValidId(dateId) && isValidProgress(incoming());
        allow update: if isOwner(userId) && isValidId(dateId) && isValidProgress(incoming()) &&
                        incoming().userId == existing().userId;
        allow delete: if isOwner(userId) && isValidId(dateId);
      }

      match /messages/{messageId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(messageId);
        allow create: if isOwner(userId) && isValidId(messageId) && isValidMessage(incoming());
        allow delete: if isOwner(userId) && isValidId(messageId);
      }

      match /profile/data {
        allow get, write: if isOwner(userId);
      }

      match /goals/{goalId} {
        allow list: if isOwner(userId);
        allow get, create, update, delete: if isOwner(userId) && isValidId(goalId) && (request.method != 'create' && request.method != 'update' || isValidGoal(incoming()));
      }

      match /insights/{insightId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidInsight(incoming());
        allow delete: if isOwner(userId);
      }
    }
  }
}
